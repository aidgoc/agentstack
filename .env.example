# Required — get these from Telegram:
#   Bot token:  open @BotFather → /newbot
#   Your ID:    open @userinfobot → /start
TELEGRAM_BOT_TOKEN=your-bot-token
OWNER_ID=your-telegram-user-id

# Claude Code authentication (choose one):
#
#   Option A — API key (recommended for servers, works headlessly)
#   Get one at: https://console.anthropic.com/settings/keys
#   ANTHROPIC_API_KEY=sk-ant-...
#
#   Option B — Claude subscription (OAuth)
#   Leave blank and run `claude` locally once to authenticate via browser.
#   IMPORTANT: Do this via SSH, not from the Telegram terminal.

# Auto-set by start.sh on each launch — do not edit
# AGENTSTACK_WEBAPP_URL=

# Optional tuning
# WEB_TOKEN_TTL=14400   # session token lifetime in seconds (default: 4 hours)
