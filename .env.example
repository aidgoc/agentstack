# Required
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather

# Admin users (comma-separated Telegram user IDs) — can use /sh, /admin, /reload
TELEGRAM_ADMIN_USERS=

# Per-user session limit (default: 10)
MAX_SESSIONS_PER_USER=10

# Auto-set by start.sh — do not edit manually
# AGENTSTACK_WEBAPP_URL=
