{
  "mcpServers": {
    "fetch": {
      "command": "uvx",
      "args": ["mcp-server-fetch"],
      "env": {}
    },
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem",
               "{{AGENTSTACK_HOME}}/shared/marketing",
               "{{AGENTSTACK_HOME}}/shared/social",
               "{{AGENTSTACK_HOME}}/shared/research"]
    }
  }
}
