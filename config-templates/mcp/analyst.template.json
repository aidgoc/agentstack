{
  "mcpServers": {
    "fetch": {
      "command": "uvx",
      "args": ["mcp-server-fetch"],
      "env": {}
    },
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem",
               "{{AGENTSTACK_HOME}}/shared/analysis",
               "{{AGENTSTACK_HOME}}/shared"]
    },
    "sqlite": {
      "command": "uvx",
      "args": ["mcp-server-sqlite", "--db-path",
               "{{AGENTSTACK_HOME}}/shared/analysis/data.db"]
    }
  }
}
